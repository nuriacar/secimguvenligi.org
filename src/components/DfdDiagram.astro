}
.dfd-figure svg {
  width: 100%;
  height: auto;
}
.dfd-figure figcaption {
  text-align: center;
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-top: 0.5rem;
  font-style: italic;
}
</style>
